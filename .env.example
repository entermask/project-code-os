# API bearer token. Required for all /v1 endpoints.
API_TOKEN=change-me

# FastAPI wrapper bind address.
HOST=0.0.0.0
# GPUHub public HTTP port used in production.
PORT=6006

# TTS backend identity shown by /health.
TTS_BACKEND_NAME=bosonai/higgs-audio-v3-tts-4b

# SGLang-Omni backend. Start it separately with scripts/run_sglang.sh.
SGLANG_BASE_URL=http://127.0.0.1:8000
MODEL_PATH=bosonai/higgs-audio-v3-tts-4b
SGLANG_HOST=127.0.0.1
SGLANG_PORT=8000

# Leave empty for Higgs Audio v3.
SGLANG_CONFIG=
SGLANG_ALLOWED_LOCAL_MEDIA_PATH=/root/autodl-tmp/tts-cache
SGLANG_MEM_FRACTION_STATIC=
SGLANG_CPU_OFFLOAD_GB=
SGLANG_EXTRA_ARGS=

# Optional. Set for vLLM-Omni style endpoints that require a model field in
# /v1/audio/speech requests.
SPEECH_MODEL=

# Local cache/job storage. Must be readable by the SGLang process because
# reference audio is passed to SGLang as a local audio_path.
TTS_CACHE_DIR=/root/autodl-tmp/tts-cache

# Keep model cache on the system disk. Keep generated/reference audio on data.
HF_HOME=/root/.cache/huggingface

# Request and job controls.
MAX_CONCURRENT_CHUNKS=16
MAX_IN_FLIGHT_CHUNKS_PER_JOB=10
# Ngưỡng shed tải/bridge: khi backlog HIỆN TẠI >= ngưỡng thì trả 429 → worker đổi sang bridge rảnh.
# LƯU Ý: 1 job có thể >100-400 chunk; admission luôn nhận 1 job khi backlog dưới ngưỡng (kể cả job
# lớn hơn ngưỡng) nên KHÔNG đặt quá thấp kẻo churn 429. Least-loaded routing lo phần rải đều.
# Job thật có thể 400-960 chunk/request → đặt đủ cao; least-loaded routing lo phần rải đều,
# option C trong _try_reserve_chunks đảm bảo 1 job lớn LUÔN được nhận dù chunk_count > cap.
# (Trước đây để 2000 gây dồn ~1600 chunk/1 bridge khi còn round-robin.)
BUSY_BACKLOG_CHUNKS=800
# Lane riêng cho job ngắn để không xếp hàng sau job dài.
SHORT_RESERVED_CHUNKS=4
SHORT_REQUEST_MAX_CHARS=1000
SHORT_REQUEST_MAX_CHUNKS=4
DOWNLOAD_TIMEOUT=60
REQUEST_TIMEOUT=600
JOB_TTL_SECONDS=3600
# After a client has fully streamed all chunks, keep generated job audio briefly
# for retry races, then delete it. Jobs that are never fully streamed use
# JOB_TTL_SECONDS.
STREAMED_JOB_TTL_SECONDS=60
JOB_CLEANUP_INTERVAL_SECONDS=30
# HTTP response file-read block size. This is not TTS chunking.
STREAM_CHUNK_SIZE_BYTES=4194304

# Per-chunk retry: lỗi tạm từ SGLang hoặc audio rỗng/quá nhỏ (gần-câm/cụt) → sinh lại,
# tránh giết cả job và tránh "đọc thiếu chữ". CHUNK_MIN_BYTES=0 để tắt kiểm tra kích thước.
CHUNK_RETRY_ATTEMPTS=3
CHUNK_RETRY_BASE_DELAY=1.0
CHUNK_MIN_BYTES=512

# "Chặn dưới" early-EOS (đọc THIẾU chữ): nếu completion_tokens thực < EARLY_EOS_RATIO × kỳ vọng
# từ độ dài text → chunk đọc cụt → re-render đổi seed (best-effort sau khi hết lượt, không skip).
# Tăng (vd 0.6) = bắt gắt hơn nhưng dễ false-positive ở chunk đọc nhanh; giảm = nới lỏng.
# Chỉ áp cho chunk đủ dài (kỳ vọng >= EARLY_EOS_MIN_EXPECTED_TOKENS) để tránh false-pos chunk ngắn.
EARLY_EOS_RATIO=0.5
EARLY_EOS_MIN_EXPECTED_TOKENS=96

# Higgs v3 default sampling injected when the client omits these (client values win).
# temperature + top_k are the stability levers (match boson voice-clone / v3 model card).
# HIGGS_TOP_P: leave EMPTY for the Higgs v3 default (top_p unset = nucleus OFF). Set a number
# (e.g. 0.95) only to re-enable nucleus filtering as an anti-silence-attractor measure.
HIGGS_TEMPERATURE=0.8
HIGGS_TOP_P=
HIGGS_TOP_K=50

# Optional ffmpeg binary used when format=mp3 and SGLang returns WAV bytes.
FFMPEG_BIN=ffmpeg

# Logging.
LOG_LEVEL=INFO
